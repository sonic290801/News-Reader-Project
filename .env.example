# Database
DATABASE_URL=postgresql://newsreader:newsreader@db:5432/newsreader

# Auth — change both of these before sharing
AUTH_PASSWORD=changeme
AUTH_SECRET=replace-with-random-32-char-string

# AI — local (default)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b

# AI — cloud fallback (get free key from aistudio.google.com)
GEMINI_API_KEY=

# Set automatically by Netlify — do not set manually
# NETLIFY=true
